# Çakatech sitesi ortam değişkenleri — bu dosyayı .env olarak kopyalayıp doldurun.
# cp .env.example .env

# Django gizli anahtarı (üretimde MUTLAKA değiştirin)
# Yeni anahtar üretmek için:
#   python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
SECRET_KEY=django-insecure-degistir-beni

# Geliştirmede True, üretimde False
DEBUG=True

# Virgülle ayrılmış izinli host'lar (üretimde alan adınızı ekleyin)
ALLOWED_HOSTS=127.0.0.1,localhost

# HTTPS form gönderimleri için (üretim, örn. https://kullanici.pythonanywhere.com)
CSRF_TRUSTED_ORIGINS=

# Gizli admin paneli yolu (sonda / olmalı). Tahmin edilmesi zor bir şey seçin.
ADMIN_URL=cakatech-yonetim/
